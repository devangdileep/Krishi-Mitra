SUPABASE_URL=https://kqozeorgqzltihbycnju.supabase.co
SUPABASE_API_KEY=your_supabase_publishable_key

# Development only. Do not commit your real Groq key.
GROQ_API_KEY=your_groq_api_key

# Optional: official data.gov.in key for AGMARKNET mandi prices.
# The app falls back to the public sample key for development.
DATA_GOV_API_KEY=your_data_gov_api_key

# Production alternative: deploy supabase/functions/groq-ai and use this
# instead of compiling GROQ_API_KEY into the APK.
GROQ_PROXY_ENDPOINT=https://kqozeorgqzltihbycnju.supabase.co/functions/v1/groq-ai

# Optional human voice configuration.
DEEPGRAM_API_KEY=your_deepgram_api_key
DEEPGRAM_TTS_MODEL=aura-2-thalia-en
